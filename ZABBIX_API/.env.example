# Configurações do Zabbix - Instância 1 (ex: INCRA)
ZABBIX_URL_INCRA=https://seu-zabbix.dominio.gov.br/api_jsonrpc.php
ZABBIX_API_TOKEN_INCRA=seu_token_aqui
ZABBIX_ENDPOINTS_INCRA=host,event,maintenance  # escolha os endpoints desejados

# Configurações do Zabbix - Instância 2 (ex: MDS)
ZABBIX_URL_MDS=https://seu-zabbix.dominio.gov.br/api_jsonrpc.php
ZABBIX_API_TOKEN_MDS=seu_token_aqui
ZABBIX_ENDPOINTS_MDS=host,event,maintenance

# Configurações do Zabbix - Instância 3 (ex: MIDR)
ZABBIX_URL_MIDR=https://seu-zabbix.dominio.gov.br/api_jsonrpc.php
ZABBIX_API_TOKEN_MIDR=seu_token_aqui
ZABBIX_ENDPOINTS_MIDR=host,event,maintenance

# Adicione mais instâncias conforme necessário seguindo o padrão:
# ZABBIX_URL_<NOME>=https://...
# ZABBIX_API_TOKEN_<NOME>=...
# ZABBIX_ENDPOINTS_<NOME>=host,event,maintenance

# PostgreSQL
PG_HOST=127.0.0.1
PG_PORT=5432
PG_DB=nome_do_banco
PG_USER=usuario_do_banco
PG_PASSWORD=senha_do_banco
PG_SCHEMA=schema_do_banco

# Controle de recriação da tabela de eventos (1 = não recriar, acumular dados)
SKIP_RECREATE_EVENTS_TABLE=1
